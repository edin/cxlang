type BinaryOp = fn (int, int) -> int;
type Predicate = fn (value: int) -> int;

fn add(a: int, b: int) -> int {
    return a + b;
}

fn is_positive(value: int) -> int {
    return value > 0;
}

fn apply(op: BinaryOp, a: int, b: int) -> int {
    return op(a, b);
}

fn main() -> int {
    let op: BinaryOp = add;
    let predicate: Predicate = is_positive;
    return apply(op, 20, 22) - 42 + predicate(1) - 1;
}
