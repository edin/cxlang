fn main() -> int {
    let values: Vec<int> = Vec<int>.create();
    values.add<int>(10);
    values.add<int>(30);
    values.insert<int>(1, 20);

    let first: Option<int> = values.first<int>();
    let last: Option<int> = values.last<int>();
    let removed: Option<int> = values.swap_remove<int>(1);
    let popped: Option<int> = values.pop<int>();

    let result: int = first.value + last.value + removed.value + popped.value;
    values.free<int>();
    return result - 90;
}
