fn classify(value: int) -> int {
    if (value < 0) {
        return -1;
    } else if (value == 0) {
        return 0;
    } else if (value < 10) {
        return 1;
    } else {
        return 2;
    }
}

fn main() -> int {
    let total: int = 0;

    for (let i: int = 0; i < 5; i += 1) {
        total += classify(i);
    }

    while (total > 0) {
        total -= 1;
    }

    return total;
}
